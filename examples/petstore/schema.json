{
  "name": "petstore",
  "version": "0.1.0",
  "language": {
    "csharp": {
      "respectSchemaVersion": true
    },
    "go": {
      "generateResourceContainerTypes": true,
      "importBasePath": "local-package/sdk/go/petstore",
      "respectSchemaVersion": true
    },
    "nodejs": {
      "respectSchemaVersion": true
    },
    "python": {
      "pyproject": {
        "enabled": true
      },
      "respectSchemaVersion": true
    }
  },
  "config": {
    "variables": {
      "apiKey": {
        "type": "string",
        "description": "API key value.",
        "secret": true
      },
      "apiKeyHeader": {
        "type": "string",
        "description": "HTTP header name for the API key (default: api_key)."
      },
      "baseUrl": {
        "type": "string",
        "description": "Base URL for the API (overrides the spec server URL)."
      },
      "bearerToken": {
        "type": "string",
        "description": "Bearer token for the Authorization header.",
        "secret": true
      }
    }
  },
  "types": {
    "petstore:index:Category": {
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "petstore:index:Tag": {
      "properties": {
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "provider": {
    "inputProperties": {
      "apiKey": {
        "type": "string",
        "description": "API key value.",
        "secret": true
      },
      "apiKeyHeader": {
        "type": "string",
        "description": "HTTP header name for the API key (default: api_key)."
      },
      "baseUrl": {
        "type": "string",
        "description": "Base URL for the API (overrides the spec server URL)."
      },
      "bearerToken": {
        "type": "string",
        "description": "Bearer token for the Authorization header.",
        "secret": true
      }
    }
  },
  "resources": {
    "petstore:index:Pet": {
      "properties": {
        "category": {
          "$ref": "#/types/petstore:index:Category"
        },
        "id": {
          "type": "integer"
        },
        "name": {
          "type": "string"
        },
        "photoUrls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "description": "pet status in the store"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/types/petstore:index:Tag"
          }
        }
      },
      "inputProperties": {
        "category": {
          "$ref": "#/types/petstore:index:Category"
        },
        "name": {
          "type": "string"
        },
        "photoUrls": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "status": {
          "type": "string",
          "description": "pet status in the store"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/types/petstore:index:Tag"
          }
        }
      },
      "requiredInputs": [
        "name",
        "photoUrls"
      ]
    },
    "petstore:index:StoreOrder": {
      "properties": {
        "complete": {
          "type": "boolean"
        },
        "id": {
          "type": "integer"
        },
        "petId": {
          "type": "integer"
        },
        "quantity": {
          "type": "integer"
        },
        "shipDate": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "description": "Order Status"
        }
      },
      "inputProperties": {
        "complete": {
          "type": "boolean"
        },
        "petId": {
          "type": "integer"
        },
        "quantity": {
          "type": "integer"
        },
        "shipDate": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "description": "Order Status"
        }
      }
    },
    "petstore:index:User": {
      "properties": {
        "email": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "id": {
          "type": "integer"
        },
        "lastName": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "userStatus": {
          "type": "integer",
          "description": "User Status"
        },
        "username": {
          "type": "string"
        }
      },
      "inputProperties": {
        "email": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "password": {
          "type": "string"
        },
        "phone": {
          "type": "string"
        },
        "userStatus": {
          "type": "integer",
          "description": "User Status"
        },
        "username": {
          "type": "string"
        }
      }
    }
  }
}
